# GitHub 评论功能配置
# 请复制此文件为 .env 并填写配置

# GitHub Personal Access Token（可选，未配置时读取 localStorage）
# 获取方式：https://github.com/settings/tokens
# 需要权限：repo (所有仓库) 或 repo:comments (仅评论)
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub 仓库配置（必填）
# 用于存储博客评论的仓库所有者（用户名或组织名）
VITE_GITHUB_REPO_OWNER=your-username

# 用于存储博客评论的仓库名称
VITE_GITHUB_REPO_NAME=blog-comments

# 示例配置：
# VITE_GITHUB_REPO_OWNER=myusername
# VITE_GITHUB_REPO_NAME=my-blog-comments
