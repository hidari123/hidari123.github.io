# ========================================
# Giscus 评论系统配置
# ========================================
# Giscus 是基于 GitHub Discussions 的评论系统
# 访问 https://giscus.app 获取配置参数

# 格式：用户名/仓库名
VITE_GISCUS_REPO=your-username/your-repo

# 仓库 ID（从 giscus.app 获取）
VITE_GISCUS_REPO_ID=R_xxxxxxxxxxxxxxx

# 分类名称
VITE_GISCUS_CATEGORY=Announcements

# 分类 ID（从 giscus.app 获取）
VITE_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxxxxxxx

# ========================================
# 旧版 GitHub Issues 评论配置（已弃用）
# ========================================
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# VITE_GITHUB_REPO_OWNER=your-username
# VITE_GITHUB_REPO_NAME=blog-comments
